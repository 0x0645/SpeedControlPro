{
  "name": "speedcontrol-pro",
  "version": "1.0.0",
  "description": "Precise playback speed control for HTML5 video and audio — per-site profiles, keyboard shortcuts, and a refined interface",
  "type": "module",
  "packageManager": "pnpm@9.11.0",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && tsx tests/e2e/run-e2e.ts",
    "test:browser": "echo 'Open tests/fixtures/test-page.html in browser'",
    "serve": "python3 -m http.server 8000",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --project tsconfig.json",
    "zip": "pnpm build && node scripts/zip.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@tailwindcss/cli": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "1.6.1",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "fs-extra": "^11.2.0",
    "globals": "^13.24.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.1.0",
    "puppeteer": "^24.10.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "1.6.1"
  },
  "prettier": {
    "singleQuote": true,
    "semi": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  }
}
